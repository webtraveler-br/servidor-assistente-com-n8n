# n8n (core)
N8N_USER=
N8N_PASS=
N8N_HOST=
N8N_ENCRYPTION_KEY=

# n8n (runtime)
N8N_PROTOCOL=https
N8N_PROXY_HOPS=1
N8N_LOG_LEVEL=debug
N8N_EXECUTIONS_DATA_SAVE_ON_SUCCESS=all
N8N_EXECUTIONS_DATA_SAVE_ON_ERROR=all
N8N_ENV_VARS_UI_DISPLAY=true
N8N_BLOCK_ENV_ACCESS_IN_NODE=false
GENERIC_TIMEZONE=America/Sao_Paulo
TZ=America/Sao_Paulo

# deploy/infra
DEPLOY_SSH_HOST=
DEPLOY_SSH_OPTS=-o ConnectTimeout=10 -o StrictHostKeyChecking=accept-new
DEPLOY_REMOTE_REPO_DIR=/home/fsociety/assistant
DEPLOY_GIT_REMOTE=origin
DEPLOY_GIT_BRANCH=main
N8N_CONTAINER_NAME=n8n

# Telegram
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_NOTES_GROUP_ID=

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=minimax/minimax-m2.5:free
# Sem barra final
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Moodle UTFPR
# Sem barra final
MOODLE_URL=https://moodle.utfpr.edu.br
MOODLE_TOKEN=

# Google Classroom API
# Sem barra final
CLASSROOM_API_BASE_URL=https://classroom.googleapis.com/v1

# Portal Aluno UTFPR (/aulas)
# Sem barra final
UTFPR_PORTAL_BASE_URL=https://webapp.utfpr.edu.br/portalAluno/ws
UTFPR_PORTAL_USERNAME=
UTFPR_PORTAL_PASSWORD=
UTFPR_COD_ALUNO=
UTFPR_COMMUTE_MINUTES=20
UTFPR_PREP_MINUTES=45

# Google OAuth2 (configurado no n8n Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Futuro
GOOGLE_SHEETS_FINANCE_ID=
GOOGLE_SHEETS_NOTES_ID=
